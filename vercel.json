    { "source": "/en/Home", "destination": "/en/homepage.html" },
    { "source": "/Cours", "destination": "/classes.html" },
    { "source": "/en/Classes", "destination": "/en/classes.html" },
    { "source": "/Planning", "destination": "/planning.html" },
    { "source": "/en/Schedule", "destination": "/en/planning.html" },
    { "source": "/Contact", "destination": "/contact.html" },
    { "source": "/en/Contact", "destination": "/en/contact.html" },
    { "source": "/Tarifs", "destination": "/pricing.html" },
    { "source": "/en/Pricing", "destination": "/en/pricing.html" },
    { "source": "/Mentions-legales", "destination": "/legal.html" },
